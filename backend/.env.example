# Backend environment variables
# Copy this file to .env and fill in the values:  cp .env.example .env

# Port the API server listens on
PORT=5000

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@db:5432/taskdb?schema=public"

# Redis connection string
REDIS_URL="redis://redis:6379"

# Secrets used to sign JWT access and refresh tokens (change these!)
JWT_SECRET="your-jwt-secret-key-change-it"
REFRESH_TOKEN_SECRET="your-refresh-secret-key-change-it"

# Application environment: development | production | test
NODE_ENV=development
